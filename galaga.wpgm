import jugador.*
import config.*
import hud.*

program galaga{
    game.title("Galaga")
    //Dimensiones del tablero
    game.height(16)
    game.width(16)
    game.cellSize(32)
    //Background 
    game.boardGround("background.png")
    //Visuals 
    game.addVisual(jugador)
    game.addVisual(contadorVidas)
    //game.addVisual(contadorVidas)
    //keybinds 
    config.keybinds()
    onTicks.tick()
    game.start() 
}
